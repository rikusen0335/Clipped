{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipped",
  "version": "0.1.0",
  "identifier": "dev.rikusen.clipped",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clipped",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/ffmpeg"],
    "licenseFile": "../LICENSE",
    "resources": {
      "../LICENSE": "LICENSE.txt",
      "../THIRD-PARTY-LICENSES.md": "THIRD-PARTY-LICENSES.md",
      "../licenses/GPL-3.0.txt": "licenses/GPL-3.0.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "languages": ["English", "Japanese"]
      }
    }
  }
}
